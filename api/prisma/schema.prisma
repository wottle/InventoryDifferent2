generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  devices     Device[]
}

model Device {
  id                  Int       @id @default(autoincrement())
  name                String
  additionalName      String?
  manufacturer        String?
  modelNumber         String?
  serialNumber        String?
  releaseYear         Int?
  locationId          Int?
  location            Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  info                String?   @db.Text
  isFavorite          Boolean   @default(false)

  // Status & Condition
  status              Status    @default(COLLECTION)
  functionalStatus    FunctionalStatus @default(YES)
  condition           Condition?
  rarity              Rarity?
  lastPowerOnDate     DateTime?
  hasOriginalBox      Boolean   @default(false)
  isAssetTagged       Boolean   @default(false)

  // Acquisition & Value
  dateAcquired        DateTime?
  whereAcquired       String?
  priceAcquired       Decimal?  @db.Decimal(10, 2)
  estimatedValue      Decimal?  @db.Decimal(10, 2)

  // Sales Info
  listPrice           Decimal?  @db.Decimal(10, 2)
  soldPrice           Decimal?  @db.Decimal(10, 2)
  soldDate            DateTime?

  // Computer Specs
  cpu                 String?
  ram                 String?
  graphics            String?
  storage             String?
  operatingSystem     String?
  isWifiEnabled       Boolean?
  isPramBatteryRemoved Boolean?
  deleted             Boolean   @default(false)

  // Historical / descriptive
  historicalNotes     String?   @db.Text

  // External
  externalUrl         String?

  // Relations
  categoryId          Int
  category            Category  @relation(fields: [categoryId], references: [id])
  
  images              Image[]
  notes               Note[]
  maintenanceTasks    MaintenanceTask[]
  tags                Tag[]
  customFieldValues   CustomFieldValue[]
  valueSnapshots      ValueSnapshot[]
  pageViews           DevicePageView[]
  accessories         DeviceAccessory[]
  links               DeviceLink[]
  showcaseDevices     ShowcaseDevice[]
}

model DeviceAccessory {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@unique([deviceId, name])
}

model DeviceLink {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  type    CategoryType
  sortOrder Int    @default(0)

  devices Device[]
  templates Template[]
  wishlistItems WishlistItem[]
}

model WishlistItem {
  id                   Int       @id @default(autoincrement())
  name                 String
  additionalName       String?
  manufacturer         String?
  modelNumber          String?
  releaseYear          Int?
  targetPrice          Decimal?  @db.Decimal(10, 2)
  sourceUrl            String?
  sourceNotes          String?
  notes                String?   @db.Text
  priority             Int       @default(2)
  group                String?
  deleted              Boolean   @default(false)
  createdAt            DateTime  @default(now())
  // Spec fields (populated via template or manually)
  cpu                  String?
  ram                  String?
  graphics             String?
  storage              String?
  operatingSystem      String?
  externalUrl          String?
  isWifiEnabled        Boolean?
  isPramBatteryRemoved Boolean?
  category             Category? @relation(fields: [categoryId], references: [id])
  categoryId           Int?
}

model Image {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  path        String
  thumbnailPath String?
  dateTaken   DateTime @default(now())
  caption     String?
  isShopImage Boolean  @default(false)
  isThumbnail Boolean  @default(false)
  thumbnailMode ThumbnailMode @default(BOTH)
  isListingImage Boolean @default(false)
}

model Note {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  content     String   @db.Text
  date        DateTime @default(now())
}

model MaintenanceTask {
  id            Int      @id @default(autoincrement())
  deviceId      Int
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  label         String
  dateCompleted DateTime
  notes         String?  @db.Text
  cost          Decimal? @db.Decimal(10, 2)
}

model Tag {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  devices Device[]
}

model Template {
  id      Int    @id @default(autoincrement())
  name    String
  additionalName  String?
  manufacturer    String?
  modelNumber     String?
  releaseYear     Int?
  estimatedValue  Decimal?  @db.Decimal(10, 2)
  cpu             String?
  ram             String?
  graphics        String?
  storage         String?
  operatingSystem String?
  externalUrl     String?
  externalLinkLabel String?
  isWifiEnabled       Boolean?
  isPramBatteryRemoved Boolean?
  rarity          Rarity?
  historicalNotes String?   @db.Text

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

model CustomField {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isPublic  Boolean  @default(false)
  sortOrder Int      @default(0)

  values    CustomFieldValue[]
}

model CustomFieldValue {
  id            Int         @id @default(autoincrement())
  customFieldId Int
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  deviceId      Int
  device        Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  value         String

  @@unique([customFieldId, deviceId])
}

model ValueSnapshot {
  id             Int      @id @default(autoincrement())
  deviceId       Int
  device         Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  estimatedValue Decimal? @db.Decimal(10, 2)
  snapshotDate   DateTime @default(now())

  @@index([deviceId])
}

model DevicePageView {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([deviceId, viewedAt])
}

model TimelineEvent {
  id             Int      @id @default(autoincrement())
  year           Int
  title          String
  description    String   @db.Text
  titleDe        String?
  descriptionDe  String?  @db.Text
  titleFr        String?
  descriptionFr  String?  @db.Text
  type           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SystemSetting {
  key   String @id
  value String
}

enum Status {
  COLLECTION
  FOR_SALE
  PENDING_SALE
  SOLD
  DONATED
  IN_REPAIR
  REPAIRED
  RETURNED
}

enum FunctionalStatus {
  YES
  PARTIAL
  NO
}

enum Condition {
  NEW
  LIKE_NEW
  VERY_GOOD
  GOOD
  ACCEPTABLE
  FOR_PARTS
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  EXTREMELY_RARE
}

enum CategoryType {
  COMPUTER
  PERIPHERAL
  ACCESSORY
  OTHER
}

enum ThumbnailMode {
  BOTH
  LIGHT
  DARK
}

model ShowcaseJourney {
  id             String            @id @default(uuid())
  title          String
  slug           String            @unique
  description    String
  coverImagePath String?
  sortOrder      Int               @default(0)
  published      Boolean           @default(false)
  chapters       ShowcaseChapter[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ShowcaseChapter {
  id          String           @id @default(uuid())
  journey     ShowcaseJourney  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  journeyId   String
  title       String
  description String
  sortOrder   Int              @default(0)
  devices     ShowcaseDevice[]
}

model ShowcaseDevice {
  id          String          @id @default(uuid())
  chapter     ShowcaseChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chapterId   String
  device      Device          @relation(fields: [deviceId], references: [id])
  deviceId    Int
  curatorNote String?
  sortOrder   Int             @default(0)
  isFeatured  Boolean         @default(false)
}

model ShowcaseQuote {
  id        String  @id @default(uuid())
  author    String
  text      String
  source    String?
  isDefault Boolean @default(false)
  isEnabled Boolean @default(true)
  sortOrder Int     @default(0)
}

model ShowcaseConfig {
  id                  String  @id @default("singleton")
  siteTitle           String  @default("The Collection")
  tagline             String  @default("")
  bioText             String  @default("")
  heroImagePath       String?
  accentColor         String  @default("#0058bc")
  timelineCuratorNote String  @default("")
  narrativeStatement  String  @default("")
  collectionOverview  String  @default("")
}
