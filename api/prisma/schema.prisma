generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id                  Int       @id @default(autoincrement())
  name                String
  additionalName      String?
  manufacturer        String?
  modelNumber         String?
  serialNumber        String?
  releaseYear         Int?
  location            String?
  info                String?   @db.Text
  isFavorite          Boolean   @default(false)

  // Status & Condition
  status              Status    @default(COLLECTION)
  functionalStatus    FunctionalStatus @default(YES)
  lastPowerOnDate     DateTime?
  hasOriginalBox      Boolean   @default(false)
  isAssetTagged       Boolean   @default(false)

  // Acquisition & Value
  dateAcquired        DateTime?
  whereAcquired       String?
  priceAcquired       Decimal?  @db.Decimal(10, 2)
  estimatedValue      Decimal?  @db.Decimal(10, 2)

  // Sales Info
  listPrice           Decimal?  @db.Decimal(10, 2)
  soldPrice           Decimal?  @db.Decimal(10, 2)
  soldDate            DateTime?

  // Computer Specs
  cpu                 String?
  ram                 String?
  graphics            String?
  storage             String?
  operatingSystem     String?
  isWifiEnabled       Boolean?
  isPramBatteryRemoved Boolean?
  deleted             Boolean   @default(false)

  // External
  externalUrl         String?

  // Relations
  categoryId          Int
  category            Category  @relation(fields: [categoryId], references: [id])
  
  images              Image[]
  notes               Note[]
  maintenanceTasks    MaintenanceTask[]
  tags                Tag[]
  customFieldValues   CustomFieldValue[]
  valueSnapshots      ValueSnapshot[]
  pageViews           DevicePageView[]
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  type    CategoryType
  sortOrder Int    @default(0)

  devices Device[]
  templates Template[]
  wishlistItems WishlistItem[]
}

model WishlistItem {
  id                   Int       @id @default(autoincrement())
  name                 String
  additionalName       String?
  manufacturer         String?
  modelNumber          String?
  releaseYear          Int?
  targetPrice          Decimal?  @db.Decimal(10, 2)
  sourceUrl            String?
  sourceNotes          String?
  notes                String?   @db.Text
  priority             Int       @default(2)
  group                String?
  deleted              Boolean   @default(false)
  createdAt            DateTime  @default(now())
  // Spec fields (populated via template or manually)
  cpu                  String?
  ram                  String?
  graphics             String?
  storage              String?
  operatingSystem      String?
  externalUrl          String?
  isWifiEnabled        Boolean?
  isPramBatteryRemoved Boolean?
  category             Category? @relation(fields: [categoryId], references: [id])
  categoryId           Int?
}

model Image {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  path        String
  thumbnailPath String?
  dateTaken   DateTime @default(now())
  caption     String?
  isShopImage Boolean  @default(false)
  isThumbnail Boolean  @default(false)
  isListingImage Boolean @default(false)
}

model Note {
  id          Int      @id @default(autoincrement())
  deviceId    Int
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  content     String   @db.Text
  date        DateTime @default(now())
}

model MaintenanceTask {
  id            Int      @id @default(autoincrement())
  deviceId      Int
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  label         String
  dateCompleted DateTime
  notes         String?  @db.Text
  cost          Decimal? @db.Decimal(10, 2)
}

model Tag {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  devices Device[]
}

model Template {
  id      Int    @id @default(autoincrement())
  name    String
  additionalName  String?
  manufacturer    String?
  modelNumber     String?
  releaseYear     Int?
  estimatedValue  Decimal?  @db.Decimal(10, 2)
  cpu             String?
  ram             String?
  graphics        String?
  storage         String?
  operatingSystem String?
  externalUrl     String?
  isWifiEnabled       Boolean?
  isPramBatteryRemoved Boolean?

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

model CustomField {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isPublic  Boolean  @default(false)
  sortOrder Int      @default(0)

  values    CustomFieldValue[]
}

model CustomFieldValue {
  id            Int         @id @default(autoincrement())
  customFieldId Int
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  deviceId      Int
  device        Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  value         String

  @@unique([customFieldId, deviceId])
}

model ValueSnapshot {
  id             Int      @id @default(autoincrement())
  deviceId       Int
  device         Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  estimatedValue Decimal? @db.Decimal(10, 2)
  snapshotDate   DateTime @default(now())

  @@index([deviceId])
}

model DevicePageView {
  id        Int      @id @default(autoincrement())
  deviceId  Int
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([deviceId, viewedAt])
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  year        Int
  title       String
  description String   @db.Text
  type        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Status {
  COLLECTION
  FOR_SALE
  PENDING_SALE
  SOLD
  DONATED
  IN_REPAIR
  RETURNED
}

enum FunctionalStatus {
  YES
  PARTIAL
  NO
}

enum CategoryType {
  COMPUTER
  PERIPHERAL
  ACCESSORY
  OTHER
}
