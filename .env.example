# Production Environment Configuration
# Copy this file to .env and configure for your deployment

# Set the language for the web front end (en, de, fr)
LANGUAGE=en

# Domain Configuration
DOMAIN=inventory.example.com
SHOP_DOMAIN=shop.example.com

# Database Configuration
POSTGRES_USER=inventory
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=inventory

# Authentication
# Set a username for admin access (optional - if set, username will be required for login)
AUTH_USERNAME=admin
# Set a secure password for admin access
AUTH_PASSWORD=your_secure_admin_password_here
# JWT secret for token signing (auto-generated if not set, but recommended to set for persistence across restarts)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# AI Image Generation (optional)
# Set on the API container at runtime — never baked into the Docker image
OPENAI_API_KEY=

# Claude Sonnet Collection Assistant (optional)
ANTHROPIC_API_KEY=

# MCP Server Configuration
MCP_TOKEN=your_mcp_token_here # (optional - if set, MCP server will require this token for authentication)

# Storefront Configuration
# Contact email displayed on the shop pages (runtime env var)
CONTACT_EMAIL=store@example.com

# Umami Analytics
# If you run a umami server, set these values after creating sites in the Umami dashboard
UMAMI_URL=https://analytics.yourdomain.com
UMAMI_WEBSITE_ID=<website-id-from-umami-dashboard>
UMAMI_STOREFRONT_WEBSITE_ID=<website-id-from-umami-dashboard>
UMAMI_SHOWCASE_WEBSITE_ID=<website-id-from-umami-dashboard>

# Storage Path (absolute path on host)
UPLOADS_PATH=/path/to/inventory/uploads

