# Production Environment Configuration
# Copy this file to .env and configure for your deployment

# Domain Configuration
DOMAIN=inventory.example.com

# Database Configuration
POSTGRES_USER=inventory
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=inventory

# Authentication
# Set a username for admin access (optional - if set, username will be required for login)
AUTH_USERNAME=admin
# Set a secure password for admin access
AUTH_PASSWORD=your_secure_admin_password_here
# JWT secret for token signing (auto-generated if not set, but recommended to set for persistence across restarts)
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# Storefront Configuration
# Contact email displayed on the shop pages (runtime env var)
CONTACT_EMAIL=store@example.com

# Traefik Configuration
CERT_RESOLVER=letsencrypt

# Storage Path (absolute path on NAS)
UPLOADS_PATH=/volume1/docker/inventory/uploads
